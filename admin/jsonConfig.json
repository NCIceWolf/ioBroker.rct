{
    "i18n": true,
    "type": "tabs",
    "tabsStyle": {
        "width": "calc(100% - 100px)"
    },
    "items": {
        "_StandardTab":{
            "type": "panel",
            "label": "General settings",
            "items": {
                "_Headline1": {
                    "newLine": true,
                    "type": "header",
                    "size": 1,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "text": "General Settings"
                 },
                "dividerHdr": {
                    "newLine": true,
                    "type": "header",
                    "text": "---",
                    "size": 2
                },
                "rct_ip": {
                    "newLine": true,
                    "type": "text",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "label": "RCT ip-address",
                    "help": "Local RCT inverter ip-address (i.e. 192.168.0.10)"
                },
               "rct_refresh": {
                    "type": "number",
                    "min": 10,
                    "max": 3600,
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "label": "Refresh interval",
                    "help": "Desired refresh interval for elements in seconds (10 - 3600)"
                },
              "rct_elements": {
                    "newLine": true,
                    "type": "text",
                    "xs": 12,
                    "sm": 12,
                    "md": 6,
                    "lg": 4,
                    "xl": 4,
                    "label": "Elements",
                    "help": "Elements to be fetched from inverter (leave blank for standard)"
                }
            }
        },
        
        "_WriteSettingsTab":{
            "type": "panel",
            "label": "Write settings",
            "items": {
                "_Headline1": {
                    "newLine": true,
                    "type": "header",
                    "size": 1,
                    "xs": 12,
                    "sm": 12,
                    "md": 12,
                    "lg": 12,
                    "xl": 12,
                    "text": "Settings for write access to RCT inverter"
                     },
                    "dividerHdr": {
                        "newLine": true,
                        "type": "header",
                        "text": "---",
                        "size": 2
                    },
                    "Write_support": {
                        "newLine": true,
                        "type": "checkbox",
                        "xs": 12,
                        "sm": 12,
                        "md": 6,
                        "lg": 4,
                        "xl": 4,
                        "label": "Use write-support towards RCT inverter. Use at own risk!!",
                        "help": "This enables the write support to the RCT inverter. Please check help pages for further information."
                    },
                    "Power_mng.soc_min": {
                        "newLine": true,
                        "type": "text",
                        "hidden": "!data.Write_support",
                        "min": 7,
                        "max": 95,
                        "xs": 12,
                        "sm": 12,
                        "md": 6,
                        "lg": 4,
                        "xl": 4,
                        "label": "SoC-Minimum",
                        "help": "Desired value for Minimum SoC of connected RCT-Battery"
                    },
                     "Power_mng.soc_strategy": {
                        "newLine": true,
                        "type": "text",
                        "hidden": "!data.Write_support",
                        "min": 0,
                        "max": 5,
                        "xs": 12,
                        "sm": 12,
                        "md": 6,
                        "lg": 4,
                        "xl": 4,
                        "label": "SoC-Strategy",
                        "help": "Desired value for SoC-Strategy: 0: SOC-Target = SOC, 1: Constant, 2: External, 3: Median battery voltage, 4: Internal, 5: Timeplan (Default: 4)"
                    },
                 "Power_mng.battery_power_extern": {
                        "newLine": true,
                        "type": "text",
                        "hidden": "!data.Write_support",
                        "min": -6000,
                        "max": 6000,
                        "xs": 12,
                        "sm": 12,
                        "md": 6,
                        "lg": 4,
                        "xl": 4,
                        "label": "Battery target power",
                        "help": "Desired value for battery target power (-6000W to 6000W; negative = charge, positive = discharge)"
                    }
            }
        }
    }
}
